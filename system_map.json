  "attendance_workflow": {
    "instructor_flow": [
      "1. Open instructor.html, requireAuth + instructor role",
      "2. loadCourses() → GET /api/courses",
      "3. Start Session → POST /api/session/create with course_id",
      "4. Receive session_code, display QR via QRCode.js",
      "5. QR refreshes every 5s via GET /api/session/<code>/qr-token",
      "6. Report polls every 5s via GET /api/session/<code>/report",
      "7. Close session → POST /api/session/<code>/close",
      "8. Export CSV with UTF-8 BOM for Arabic names"
    ],
    "student_flow": [
      "1. Open attendance.html",
      "2. startQrScanner() using html5-qrcode",
      "3. onQrCodeSuccess parses session_code|token",
      "4. showStudentIdForm pre-fills from localStorage chatnct_user_id",
      "5. startFaceVerify opens front camera getUserMedia",
      "6. initMediaPipe loads FaceLandmarker WASM",
      "7. POST /api/attendance/prepare to cache embedding",
      "8. Identity loop: capture frame every 1.5s → POST check_identity until verified + faceBox",
      "9. Liveness: GET challenges → _serverSideLiveness sends frames every 300ms → check_pose",
      "10. Final POST /api/attendance/verify with verified frame",
      "11. showResult success/error overlay"
    ],
    "qr_token_mechanism": {
      "algorithm": "HMAC-SHA256(QR_SECRET, session_id:timestamp) truncated to 16 hex chars",
      "rotation_interval_seconds": 5,
      "expiry_cleanup_seconds": 180,
      "single_use": true
    },
    "anti_spoofing": [
      "Rotating QR tokens",
      "Device fingerprint binding per session",
      "Rate limiting per student per action",
      "Multi-frame static image detection",
      "Liveness head pose challenges (look left/right/straight)",
      "Face confidence threshold 0.55 (FaceNet cosine)"
    ],
    "image_optimization_mobile": {
      "max_width_px": 320,
      "jpeg_quality": 0.5,
      "approx_size_kb": 20
    }
  },

  "face_verification_engine": {
    "file": "mainAgent/web/face_verifier.py",
    "class": "FaceVerifier",
    "technologies": {
      "deepface_model": "Facenet",
      "distance_metric": "cosine",
      "detector_backend": "opencv",
      "verify_threshold": 0.55,
      "max_image_dimension": 640,
      "liveness": "MediaPipe FaceLandmarker (468 landmarks) with OpenCV fallback",
      "model_file": "mainAgent/web/face_landmarker.task"
    },
    "embedding_cache": "Thread-safe in-memory cache per registered photo path",
    "debug_mode": {
      "env": "DEBUG_FACE_PIPELINE",
      "logger": "mainAgent/web/face_debug_logger.py",
      "output": "debug_logs/ with step images and FULL_REPORT.html"
    }
  },

