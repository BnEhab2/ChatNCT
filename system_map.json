  "architecture": {
    "pattern": "Microservices-lite (2 Flask servers + static frontend)",
    "components": [
      {
        "name": "Main Server",
        "file": "server.py",
        "port": 5000,
        "protocol": "HTTPS (self-signed SSL via generate_cert.py)",
        "responsibilities": [
          "Serve frontend static files (HTML/CSS/JS/images)",
          "Chat API with Google ADK root agent",
          "Chat session persistence in PostgreSQL",
          "Supabase Auth login endpoint",
          "Proxy all attendance API calls to port 5001",
          "JWT token validation on protected routes",
          "Instructor role enforcement",
          "NDJSON streaming chat responses"
        ]
      },
      {
        "name": "Attendance Server",
        "file": "mainAgent/web/attendance_server.py",
        "port": 5001,
        "protocol": "HTTPS (self-signed SSL)",
        "responsibilities": [
          "QR session management",
          "HMAC rotating QR tokens",
          "Face identity verification (DeepFace FaceNet)",
          "Liveness pose challenges (MediaPipe + OpenCV)",
          "Rate limiting and device binding",
          "Attendance recording in database",
          "Student photo download from Supabase Storage",
          "Auto-close expired sessions"
        ]
      },
      {
        "name": "Frontend",
        "folder": "frontend/",
        "stack": "Vanilla HTML/CSS/JavaScript (no React/Vue)",
        "external_libraries": [
          "Font Awesome 6.4.0",
          "Google Fonts (Inter, JetBrains Mono)",
          "marked.js (chat markdown)",
          "html5-qrcode 2.3.8 (QR scanning)",
          "Three.js + GSAP (three-experience.js)",
          "Supabase JS v2 CDN",
          "QRCode.js (instructor panel)"
        ]
      },
      {
        "name": "AI Layer",
        "framework": "Google ADK (Agent Development Kit)",
        "llm_provider": "OpenRouter",
        "primary_model": "openrouter/openai/gpt-4o-mini",
        "session_storage": "InMemorySessionService (per server process, not persisted)"
      },
      {
        "name": "Database",
        "provider": "Supabase PostgreSQL",
        "connection": "DATABASE_URL env var via psycopg2 ThreadedConnectionPool (1-10 connections)",
        "migrations_file": "mainAgent/db/database.py"
      }
    ],
    "startup_flow": {
      "run_py": [
        "1. Spawn attendance server subprocess on port 5001 with SSL",
        "2. Poll TCP port 5001 up to 120s until ready",
        "3. Spawn server.py subprocess on port 5000",
        "4. Print local and LAN HTTPS URLs",
        "5. On Ctrl+C terminate both processes"
      ],
      "app_py_hf": [
        "1. Start attendance server in daemon thread on port 5001",
        "2. Wait up to 180s for port 5001",
        "3. Import server.app and run on PORT env (default 7860)"
      ]
    }
  },

