      "SUPABASE_ANON_KEY": "Supabase anonymous API key",
      "OPENROUTER_API_KEY": "OpenRouter API key for all LLM agents"
    },
    "optional": {
      "ATTENDANCE_SERVER_URL": "Default https://127.0.0.1:5001 — proxy target for main server",
      "QR_SECRET": "HMAC secret for QR tokens, default chatnct-qr-secret-2026",
      "DEBUG_FACE_PIPELINE": "1/true/yes/on enables face debug HTML reports",
      "PORT": "HF Spaces main server port, default 7860"
    },
    "env_file_locations": [
      ".env at project root",
      "mainAgent/.env (also loaded by server.py)"
    ]
  },

  "database": {
    "tables_documented_in_readme": [
      "profiles",
      "courses",
      "attendance",
      "attendance_sessions",
      "chat_sessions",
      "chat_messages",
      "lectures",
      "lecture_summaries",
      "qr_tokens",
      "rate_limits",
      "device_bindings"
    ],
    "migrations_created_by_app": {
      "chat_sessions": {
        "columns": ["id UUID PK", "student_id UUID FK→profiles", "title TEXT", "created_at TIMESTAMPTZ"],
        "index": "idx_chat_sessions_student"
      },
      "chat_messages": {
        "columns": ["id UUID PK", "session_id UUID FK", "role user|bot", "content TEXT", "created_at"],
        "index": "idx_chat_messages_session"
      },
      "qr_tokens": {
        "columns": ["id SERIAL", "session_id INTEGER", "token TEXT UNIQUE", "created_at", "used BOOLEAN"],
        "purpose": "Single-use rotating QR tokens, 180s cleanup"
      },
      "rate_limits": {
        "columns": ["student_id", "session_id", "action", "attempts", "blocked_until", "last_attempt"],
        "purpose": "Anti-spam for attendance attempts"
      },
      "device_bindings": {
        "columns": ["student_id", "session_id", "ip_address", "user_agent", "device_fingerprint"],
        "unique": "student_id + session_id",
        "purpose": "One device per student per session"
      }
    },
    "profiles_table_usage": {
      "fields_used": ["id", "name", "role", "status", "student_code"],
      "roles": ["student", "instructor", "admin"],
      "status_values": ["active", "blocked", "pending"]
    },
    "supabase_storage": {
      "bucket": "students_image",
      "path_pattern": "{student_code}.png|.jpg|.jpeg",
      "purpose": "Reference photos for face verification"
    }
  },

  "api_endpoints": {
    "main_server_port_5000": {
      "chat": [
        {"method": "POST", "path": "/api/chat", "auth": "Bearer JWT", "body": ["message", "session_id?"], "saves": "user+bot messages to DB"},
        {"method": "POST", "path": "/api/chat/stream", "auth": "Bearer JWT", "response": "NDJSON stream types: meta, delta, done, error"},
        {"method": "GET", "path": "/api/chat/sessions", "auth": "Bearer JWT", "query": ["page", "per_page"]},
        {"method": "GET", "path": "/api/chat/sessions/<id>/messages", "auth": "Bearer JWT", "query": ["page", "per_page"]},
        {"method": "DELETE", "path": "/api/chat/sessions/<id>", "auth": "Bearer JWT"},
        {"method": "PUT", "path": "/api/chat/sessions/<id>/rename", "auth": "Bearer JWT", "body": ["title"]}
      ],
      "prompt_and_code": [
        {"method": "POST", "path": "/api/prompt/generate", "auth": "Bearer JWT", "routes_to": "root_agent prompt_wizard"},
        {"method": "POST", "path": "/api/code/generate", "auth": "none", "routes_to": "root_agent vibe_coder"}
      ],
      "auth": [
        {"method": "POST", "path": "/api/auth/login", "auth": "none", "body": ["email", "password"], "returns": ["access_token", "refresh_token", "role", "username", "user_id", "is_admin"]}
      ],
      "courses_and_attendance_proxy": [
        {"method": "GET", "path": "/api/courses", "auth": "Bearer JWT"},
        {"method": "POST", "path": "/api/session/create", "auth": "Bearer JWT + instructor", "proxy": "5001", "retry": "3 attempts x 5 seconds"},
        {"method": "GET", "path": "/api/session/<code>", "auth": "Bearer JWT"},
        {"method": "GET", "path": "/api/session/<code>/qr-token", "auth": "Bearer JWT + instructor"},
        {"method": "POST", "path": "/api/attendance/verify", "auth": "Bearer JWT", "timeout": 120},
        {"method": "POST", "path": "/api/attendance/check_identity", "auth": "Bearer JWT", "timeout": 120},
        {"method": "POST", "path": "/api/attendance/check_pose", "auth": "Bearer JWT", "timeout": 10},
        {"method": "GET", "path": "/api/attendance/challenges", "auth": "Bearer JWT"},
        {"method": "POST", "path": "/api/attendance/prepare", "auth": "Bearer JWT"},
        {"method": "GET", "path": "/api/session/<code>/report", "auth": "Bearer JWT + instructor"},
        {"method": "POST", "path": "/api/session/<code>/close", "auth": "Bearer JWT + instructor"}
      ],
      "static": [
        {"method": "GET", "path": "/", "serves": "frontend/index.html"},
        {"method": "GET", "path": "/<path>", "serves": "frontend static files"}
      ]
    },
    "attendance_server_port_5001": [
      {"method": "GET", "path": "/", "returns": "service status JSON"},
      {"method": "GET", "path": "/api/courses"},
      {"method": "POST", "path": "/api/session/create", "body": ["course_id", "duration_minutes?"]},
      {"method": "GET", "path": "/api/session/<code>/qr-token"},
      {"method": "GET", "path": "/api/session/<code>"},
      {"method": "GET", "path": "/api/attendance/challenges"},
      {"method": "POST", "path": "/api/attendance/prepare", "purpose": "pre_caches_embedding"},
      {"method": "POST", "path": "/api/attendance/check_identity", "returns": ["verified", "distance", "faceBox"]},
      {"method": "POST", "path": "/api/attendance/check_pose", "returns": ["pose"]},
      {"method": "POST", "path": "/api/attendance/verify", "purpose": "final_attendance_record"},
      {"method": "GET", "path": "/api/session/<code>/report"},
      {"method": "POST", "path": "/api/session/<code>/close"}
    ],
    "error_codes_attendance": [
      "SESSION_NOT_FOUND", "SESSION_EXPIRED", "SESSION_CLOSED",
      "STUDENT_NOT_FOUND", "ATTENDANCE_DUPLICATE",
      "TOKEN_INVALID", "TOKEN_EXPIRED", "TOKEN_USED",
      "RATE_LIMITED", "DEVICE_MISMATCH",
      "FACE_NO_PHOTO", "FACE_DECODE_ERROR", "FACE_VERIFY_FAILED",
      "FACE_VERIFY_ERROR", "FACE_LOW_CONFIDENCE", "FACE_STATIC_IMAGE",
      "LIVENESS_FAILED", "MISSING_FIELDS", "COURSE_REQUIRED"
    ]
  },

